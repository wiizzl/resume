---
import Section from "@/components/Section.astro";

import { formatDate } from "@/lib/utils";

import { info } from "@/info";
---

<Section title="Formation">
  <div class="space-y-2">
    {
      info.education.map((item) => (
        <div>
          <div class="flex justify-between items-baseline font-medium">
            <h3 class="text-sm">
              <a href={item.link} target="_blank" class="font-semibold text-base hover:underline">
                {item.name}
              </a>
              , {item.location}
            </h3>
            <p class="capitalize">
              {formatDate(item.startDate)} - {formatDate(item.endDate)}
            </p>
          </div>
          <div class="flex justify-between items-baseline text-sm">
            <p>
              {item.diploma}; {item.minors.join(", ")}
            </p>
            <p>{item.result}</p>
          </div>
          {item.coursework && <p class="italic text-xs">{item.coursework.join(", ")}</p>}
        </div>
      ))
    }
  </div>
</Section>
